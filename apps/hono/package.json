{
  "name": "@zod-aot/hono",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "start": "bun src/server.ts",
    "build": "bun run build.ts",
    "generate": "zod-aot generate src/schemas.ts -o src/schemas.compiled.ts",
    "check": "zod-aot check src/schemas.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "hono": "^4.12.18",
    "zod": "catalog:",
    "zod-aot": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
