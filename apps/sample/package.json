    "build": "vite build",
    "start:built": "node dist/main.mjs"
  },
  "dependencies": {
    "zod": "^4.0.0",
    "zod-aot": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
