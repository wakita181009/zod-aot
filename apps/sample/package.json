{
  "name": "sample",
  "private": true,
  "type": "module",
  "scripts": {
    "generate": "zod-aot generate src/schemas.ts -o src/schemas.compiled.ts",
    "check": "zod-aot check src/schemas.ts",
    "start": "tsx src/main.ts",
    "build": "vite build",
    "start:built": "node dist/main.mjs"
  },
  "dependencies": {
    "zod": "catalog:",
    "zod-aot": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
