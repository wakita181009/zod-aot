{
  "name": "zod-aot",
  "version": "0.0.3",
  "description": "Compile Zod schemas into zero-overhead validation functions at build time",
  "type": "module",
  "keywords": [
    "zod",
    "validation",
    "aot",
    "compiler",
    "codegen",
    "performance",
    "schema",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/wakita181009/zod-aot.git",
    "directory": "packages/zod-aot"
  },
  "bin": {
    "zod-aot": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "imports": {
    "#src/*": "./src/*"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "tsx": "^4.0.0",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "tsx": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.11.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "zod": "^4.0.0"
  },
  "license": "MIT"
}
