{
  "name": "zod-aot",
  "version": "0.5.1",
  "description": "Compile Zod schemas into zero-overhead validation functions at build time",
  "type": "module",
  "keywords": [
    "zod",
    "validation",
    "aot",
    "compiler",
    "codegen",
    "performance",
    "schema",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/wakita181009/zod-aot.git",
    "directory": "packages/zod-aot"
  },
  "bin": {
    "zod-aot": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "imports": {
    "#src/*": {
      "types": "./src/*",
      "source": "./src/*",
      "default": "./dist/*"
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/unplugin/vite.d.ts",
      "source": "./src/unplugin/vite.ts",
      "import": "./dist/unplugin/vite.js",
      "default": "./dist/unplugin/vite.js"
    },
    "./webpack": {
      "types": "./dist/unplugin/webpack.d.ts",
      "source": "./src/unplugin/webpack.ts",
      "import": "./dist/unplugin/webpack.js",
      "default": "./dist/unplugin/webpack.js"
    },
    "./esbuild": {
      "types": "./dist/unplugin/esbuild.d.ts",
      "source": "./src/unplugin/esbuild.ts",
      "import": "./dist/unplugin/esbuild.js",
      "default": "./dist/unplugin/esbuild.js"
    },
    "./rollup": {
      "types": "./dist/unplugin/rollup.d.ts",
      "source": "./src/unplugin/rollup.ts",
      "import": "./dist/unplugin/rollup.js",
      "default": "./dist/unplugin/rollup.js"
    },
    "./rolldown": {
      "types": "./dist/unplugin/rolldown.d.ts",
      "source": "./src/unplugin/rolldown.ts",
      "import": "./dist/unplugin/rolldown.js",
      "default": "./dist/unplugin/rolldown.js"
    },
    "./bun": {
      "types": "./dist/unplugin/bun.d.ts",
      "source": "./src/unplugin/bun.ts",
      "import": "./dist/unplugin/bun.js",
      "default": "./dist/unplugin/bun.js"
    },
    "./internals": {
      "types": "./dist/internals.d.ts",
      "source": "./src/internals.ts",
      "import": "./dist/internals.js",
      "default": "./dist/internals.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "unplugin": "^3.0.0"
  },
  "peerDependencies": {
    "tsx": "^4.0.0",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "tsx": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "zod": "^4.0.0"
  },
  "license": "MIT"
}
